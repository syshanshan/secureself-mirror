# OpenAI temporarily disabled in code — mock analysis is always returned.
# Re-enable in src/lib/openai.ts when ready.
# OPENAI_API_KEY=sk-your-openai-api-key

# Optional: override default model
# OPENAI_MODEL=gpt-4o-mini

# Supabase project credentials (optional — entries saved locally in browser without these)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: service role key for server-side writes (use anon key if RLS allows insert)
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
